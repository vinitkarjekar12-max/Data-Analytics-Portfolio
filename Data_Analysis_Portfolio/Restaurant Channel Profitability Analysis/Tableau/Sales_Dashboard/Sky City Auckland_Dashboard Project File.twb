      <column caption='COGS Rate' datatype='real' name='[COGSRate]' role='measure' type='quantitative' />
      <column caption='UberEats Commission' datatype='real' name='[Calculation_0184501318967296]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[UberEatsRevenue]*[CommissionRate]' />
      </column>
      <column caption='DoorDash Commission' datatype='real' name='[Calculation_0184501319155713]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[DoorDashRevenue]*[CommissionRate]' />
      </column>
      <column caption='Net Profit' datatype='real' name='[Calculation_0508307392880640]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[DoorDashNetProfit]+[InStoreNetProfit]+[SelfDeliveryNetProfit]+[UberEatsNetProfit]' />
      </column>
      <column caption='InStore Profit' datatype='real' name='[Calculation_0508307395952641]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[InStoreRevenue]-([COGSRate]*[InStoreRevenue])-([OPEXRate]*[InStoreRevenue])' />

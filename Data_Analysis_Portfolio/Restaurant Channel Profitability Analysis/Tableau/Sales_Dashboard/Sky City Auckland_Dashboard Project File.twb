  <worksheets>
    <worksheet name='Breakdown Chart'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#898989' fontname='Tableau Medium' fontsize='9'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Original Sheet' name='federated.02u7dhn04wna471fc36el1lns4vf' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Channel' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Self Delivery&quot;'>
              <calculation class='tableau' formula='&quot;Self Delivery&quot;' />
            </column>
            <column caption='Commission Slider' datatype='real' name='[Parameter 2]' param-domain-type='range' role='measure' type='quantitative' value='0.10000000000000001'>
              <calculation class='tableau' formula='0.10000000000000001' />
              <range granularity='0.01' max='0.5' min='0.1' />
            </column>
            <column caption='Delivery Cost Slider' datatype='real' name='[Parameter 3]' param-domain-type='range' role='measure' type='quantitative' value='0.90000000000000002'>
              <calculation class='tableau' formula='0.90000000000000002' />
              <range granularity='0.1' max='5.4' min='0.8' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.02u7dhn04wna471fc36el1lns4vf'>
            <column caption='COGS Rate' datatype='real' name='[COGSRate]' role='measure' type='quantitative' />
            <column caption='Selected COGS' datatype='real' name='[Calculation_0702098481676289]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;&#13;&#10;WHEN &quot;In-Store&quot; THEN [InStoreRevenue] * [COGSRate]&#13;&#10;WHEN &quot;Uber Eats&quot; THEN [UberEatsRevenue] * [COGSRate]&#13;&#10;WHEN &quot;DoorDash&quot; THEN [DoorDashRevenue] * [COGSRate]&#13;&#10;WHEN &quot;Self Delivery&quot; THEN [SelfDeliveryRevenue] * [COGSRate]&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Selected OPEX' datatype='real' name='[Calculation_0702098481766402]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;&#13;&#10;WHEN &quot;In-Store&quot; THEN [InStoreRevenue] * [OPEXRate]&#13;&#10;WHEN &quot;Uber Eats&quot; THEN [UberEatsRevenue] * [OPEXRate]&#13;&#10;WHEN &quot;DoorDash&quot; THEN [DoorDashRevenue] * [OPEXRate]&#13;&#10;WHEN &quot;Self Delivery&quot; THEN [SelfDeliveryRevenue] * [OPEXRate]&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Selected Delivery Cost Total' datatype='real' name='[Calculation_0702098481881091]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;&#13;&#10;WHEN &quot;Self Delivery&quot; THEN &#13;&#10;    SUM([SD_DeliveryTotalCost])&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Adjusted Commission' datatype='real' name='[Calculation_1375548990894080]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Uber Eats&quot; &#13;&#10;   OR [Parameters].[Parameter 1] = &quot;DoorDash&quot;&#13;&#10;THEN [Parameters].[Parameter 2]&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='Adjusted Delivery Cost' datatype='real' name='[Calculation_1375548991070209]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Self Delivery&quot;&#13;&#10;THEN [Parameters].[Parameter 3]&#13;&#10;ELSE [DeliveryCostPerOrder]&#13;&#10;END' />
            </column>
            <column caption='Selected Profit (Adjusted)' datatype='real' name='[Calculation_1375549014601730]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;&#13;&#10;WHEN &quot;Uber Eats&quot; THEN &#13;&#10;    [UberEatsRevenue] * &#13;&#10;    (1 - [COGSRate] - [OPEXRate] - [Calculation_1375548990894080])&#13;&#10;&#13;&#10;WHEN &quot;DoorDash&quot; THEN &#13;&#10;    [DoorDashRevenue] * &#13;&#10;    (1 - [COGSRate] - [OPEXRate] - [Calculation_1375548990894080])&#13;&#10;&#13;&#10;WHEN &quot;Self Delivery&quot; THEN &#13;&#10;    [SelfDeliveryRevenue] &#13;&#10;    - ([SelfDeliveryRevenue] * [COGSRate]) &#13;&#10;    - ([SelfDeliveryRevenue] * [OPEXRate]) &#13;&#10;    - ([Calculation_1375548991070209] * [SelfDeliveryOrders])&#13;&#10;&#13;&#10;WHEN &quot;In-Store&quot; THEN &#13;&#10;    [InStoreRevenue] * (1 - [COGSRate] - [OPEXRate])&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Delivery Cost Per Order' datatype='real' name='[DeliveryCostPerOrder]' role='measure' type='quantitative' />
            <column caption='Door Dash Revenue' datatype='real' name='[DoorDashRevenue]' role='measure' type='quantitative' />
            <column caption='In Store Revenue' datatype='real' name='[InStoreRevenue]' role='measure' type='quantitative' />
            <column caption='OPEX Rate' datatype='real' name='[OPEXRate]' role='measure' type='quantitative' />
            <column caption='SD DeliveryTotalCost' datatype='real' name='[SD_DeliveryTotalCost]' role='measure' type='quantitative' />
            <column caption='Self Delivery Orders' datatype='integer' name='[SelfDeliveryOrders]' role='measure' type='quantitative' />
            <column caption='Self Delivery Revenue' datatype='real' name='[SelfDeliveryRevenue]' role='measure' type='quantitative' />
            <column caption='Uber Eats Revenue' datatype='real' name='[UberEatsRevenue]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0702098481676289]' derivation='Sum' name='[sum:Calculation_0702098481676289:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0702098481766402]' derivation='Sum' name='[sum:Calculation_0702098481766402:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0702098481881091]' derivation='Sum' name='[sum:Calculation_0702098481881091:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1375549014601730]' derivation='Sum' name='[sum:Calculation_1375549014601730:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0702098481881091]' derivation='User' name='[usr:Calculation_0702098481881091:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.02u7dhn04wna471fc36el1lns4vf].[:Measure Names]'>
            <groupfilter function='union' user:op='manual'>
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.02u7dhn04wna471fc36el1lns4vf].[sum:Calculation_0702098481766402:qk]&quot;' />
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.02u7dhn04wna471fc36el1lns4vf].[sum:Calculation_0702098481676289:qk]&quot;' />
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.02u7dhn04wna471fc36el1lns4vf].[sum:Calculation_1375549014601730:qk]&quot;' />
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.02u7dhn04wna471fc36el1lns4vf].[usr:Calculation_0702098481881091:qk]&quot;' />
            </groupfilter>

      </column>
      <column caption='Net Profit (Waterfall Chart)' datatype='real' name='[Calculation_0702098518929417]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0552839187324931]+[Selected COGS (copy)_0702098518200325]+[COGS (Waterfall Chart) (copy)_0702098518425606]+ [COGS (Waterfall Chart) (copy)_0702098518597639] + [Commission (Waterfall Chart) (copy)_0702098518741000]' />
      </column>
      <column caption='Adjusted Commission' datatype='real' name='[Calculation_1375548990894080]' role='measure' type='quantitative'>

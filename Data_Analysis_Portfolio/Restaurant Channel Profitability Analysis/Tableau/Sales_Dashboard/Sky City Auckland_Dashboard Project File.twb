      <column caption='OPEX (Waterfall Chart)' datatype='real' name='[COGS (Waterfall Chart) (copy)_0702098518425606]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='- [Calculation_0552839187324931] * [OPEXRate]' />
      </column>
      <column caption='Commission (Waterfall Chart)' datatype='real' name='[COGS (Waterfall Chart) (copy)_0702098518597639]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;&#13;&#10;WHEN &quot;Uber Eats&quot; THEN &#13;&#10;    - [Calculation_0552839187324931] * [Calculation_1375548990894080]&#13;&#10;&#13;&#10;WHEN &quot;DoorDash&quot; THEN &#13;&#10;    - [Calculation_0552839187324931] * [Calculation_1375548990894080]&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='COGS Rate' datatype='real' name='[COGSRate]' role='measure' type='quantitative' />
      <column caption='InStore COGS' datatype='real' name='[Calculation_0184501594591234]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[InStoreRevenue]*[COGSRate]' />
      </column>
      <column caption='SelfDelivery COGS' datatype='real' name='[Calculation_0184501594759171]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[SelfDeliveryRevenue]*[COGSRate]' />
      </column>
      <column caption='UberEats COGS' datatype='real' name='[Calculation_0184501594906628]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[UberEatsRevenue]*[COGSRate]' />
      </column>
      <column caption='DoorDash COGS' datatype='real' name='[Calculation_0184501595045893]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[DoorDashRevenue]*[COGSRate]' />
      </column>
      <column caption='InStore OPEX' datatype='real' name='[Calculation_0184501605281798]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[InStoreRevenue]*[OPEXRate]' />
      </column>
      <column caption='SelfDelivery OPEX' datatype='real' name='[Calculation_0184501605441543]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[SelfDeliveryRevenue]*[OPEXRate]' />
      </column>
      <column caption='UberEats OPEX' datatype='real' name='[Calculation_0184501605589000]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[UberEatsRevenue]*[OPEXRate]' />
      </column>
      <column caption='DoorDash OPEX' datatype='real' name='[Calculation_0184501605679113]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[DoorDashRevenue]*[OPEXRate]' />
      </column>
      <column caption='Overall Profit' datatype='real' name='[Calculation_0552839085441024]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[DoorDashNetProfit]+[InStoreNetProfit]+[SelfDeliveryNetProfit]+[UberEatsNetProfit]' />
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_0552839174111234]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([InStoreNetProfit]+[DoorDashNetProfit]+[SelfDeliveryNetProfit]+[UberEatsNetProfit])/([DoorDashRevenue]+[InStoreRevenue]+[SelfDeliveryRevenue]+[UberEatsRevenue])' />
      </column>
      <column caption='Selected Revenue' datatype='real' name='[Calculation_0552839187324931]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;In-Store&quot; THEN [InStoreRevenue]&#13;&#10;WHEN &quot;DoorDash&quot; THEN [DoorDashRevenue]&#13;&#10;WHEN &quot;Uber Eats&quot; THEN [UberEatsRevenue]&#13;&#10;WHEN &quot;Self Delivery&quot; THEN [SelfDeliveryRevenue]&#13;&#10;END' />
      </column>
      <column caption='Selected Profit' datatype='real' name='[Calculation_0552839190990853]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;In-Store&quot; THEN [InStoreNetProfit]&#13;&#10;WHEN &quot;DoorDash&quot; THEN [DoorDashNetProfit]&#13;&#10;WHEN &quot;Uber Eats&quot; THEN [UberEatsNetProfit]&#13;&#10;WHEN &quot;Self Delivery&quot; THEN [SelfDeliveryNetProfit]&#13;&#10;END' />
      </column>
      <column caption='Selected Orders' datatype='integer' name='[Calculation_0552839191191558]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;In-Store&quot; THEN [InStoreOrders]&#13;&#10;WHEN &quot;DoorDash&quot; THEN [DoorDashOrders]&#13;&#10;WHEN &quot;Uber Eats&quot; THEN [UberEatsOrders]&#13;&#10;WHEN &quot;Self Delivery&quot; THEN [SelfDeliveryOrders]&#13;&#10;END' />
      </column>
      <column caption='Profit Margin Selector' datatype='real' name='[Calculation_0552839194603527]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0552839190990853])/SUM([Calculation_0552839187324931])' />
      </column>
      <column caption='Selected Commission' datatype='real' name='[Calculation_0702098466885632]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;&#13;&#10;WHEN &quot;Uber Eats&quot; THEN &#13;&#10;    SUM([UberEatsRevenue]) * AVG([CommissionRate])&#13;&#10;&#13;&#10;WHEN &quot;DoorDash&quot; THEN &#13;&#10;    SUM([DoorDashRevenue]) * AVG([CommissionRate])&#13;&#10;&#13;&#10;WHEN &quot;In-Store&quot; THEN 0&#13;&#10;&#13;&#10;WHEN &quot;Self Delivery&quot; THEN 0&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Selected COGS' datatype='real' name='[Calculation_0702098481676289]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;&#13;&#10;WHEN &quot;In-Store&quot; THEN [InStoreRevenue] * [COGSRate]&#13;&#10;WHEN &quot;Uber Eats&quot; THEN [UberEatsRevenue] * [COGSRate]&#13;&#10;WHEN &quot;DoorDash&quot; THEN [DoorDashRevenue] * [COGSRate]&#13;&#10;WHEN &quot;Self Delivery&quot; THEN [SelfDeliveryRevenue] * [COGSRate]&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Selected OPEX' datatype='real' name='[Calculation_0702098481766402]' role='measure' type='quantitative'>

              <calculation class='tableau' formula='&quot;Self Delivery&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.02u7dhn04wna471fc36el1lns4vf'>
            <column caption='Selected Revenue' datatype='real' name='[Calculation_0552839187324931]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;In-Store&quot; THEN [InStoreRevenue]&#13;&#10;WHEN &quot;DoorDash&quot; THEN [DoorDashRevenue]&#13;&#10;WHEN &quot;Uber Eats&quot; THEN [UberEatsRevenue]&#13;&#10;WHEN &quot;Self Delivery&quot; THEN [SelfDeliveryRevenue]&#13;&#10;END' />

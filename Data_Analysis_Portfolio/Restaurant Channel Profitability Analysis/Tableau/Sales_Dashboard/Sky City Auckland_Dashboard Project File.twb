      <column caption='All Channels Revenue' datatype='real' name='[Calculation_1295831873474560]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[DoorDashRevenue]+[InStoreRevenue]+[SelfDeliveryRevenue]+[UberEatsRevenue]' />
      </column>
